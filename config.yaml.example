# Deployment Engine Configuration
log_file: "deployments.log"

# Repository configurations
# Every repository must have a 'path'.
# 'branch' and 'timeout' are optional and will use Python defaults if missing.
# 'commands' are optional but app will just exit without them.

repos:
  app1:
    path: "/opt/app1"
    branch: "main"
    timeout: 900
    commands:
      - git fetch origin main
      - git reset --hard origin/main
      - docker compose up -d --build
