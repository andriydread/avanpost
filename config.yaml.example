# Deployment Engine Configuration
log_file: "deployments.log"

# Global defaults (inherited by all repos unless overridden)
branch: "main"
timeout: 900
auto_cleanup: false

# If 'commands' is not provided, the default will be 'git pull' and 'docker compose'.

# Repository configurations
repos:
  app1:
    path: "/opt/app1"
    branch: "test"
    timeout: 900
    auto_cleanup: true
